{
  "name": "full-year-in-new-tab",
  "version": "2.0.0",
  "private": true,
  "description": "Full Year in New Tab — a minimal Chrome MV3 full-year calendar.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
