    "happy-dom": "^20.10.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@preact/signals": "^1.3.1",
    "preact": "^10.25.1"
  }
